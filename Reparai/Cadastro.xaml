<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Reparai.Cadastro">
    


    <ScrollView>
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
            <Label Text="Tela de Cadastro" FontSize="40" FontAttributes="Bold" HorizontalTextAlignment="Center" Margin="0,40,0,20"/>
            <Grid RowDefinitions="*,*,*,*,*,*,*,*,*,*,*,*,*" WidthRequest="400">
                <!-- NOME -->
                <Label Grid.Row="0" Text="Nome completo:"/>
                <Entry Grid.Row="1"
                       x:Name="NomeEntry"
                       Placeholder="Nome completo"
                       Margin="0,0,0,20"/>

                <!-- CPF -->
                <Label Grid.Row="2" Text="CPF:"/>
                <Entry Grid.Row="3"
                       x:Name="CpfEntry"
                       Placeholder="***.***.***-**"
                       Margin="0,0,0,20"/>
                
                <!-- DATA NASCIMENTO -->
                <!--<Label Grid.Row="4" Text="Data de nascimento:" Margin="0,0,0,0"/>
                <DatePicker Grid.Row="5" x:Name="DataNascimento" Margin="0,0,0,20"/>-->

                <!-- EMAIL -->
                <Label Grid.Row="4" Text="E-mail:"/>
                <Entry Grid.Row="5"
                       x:Name="EmailEntry"
                       Placeholder="exemplo@exemplo.com.br"
                       Margin="0,0,0,20"/>

                <!-- SENHA -->
                <Label Grid.Row="6" Text="Senha:"/>
                <Entry Grid.Row="7"
                       x:Name="SenhaEntry"
                       Placeholder="******"
                       IsPassword="True"
                       Margin="0,0,0,20"/>

                <!-- CONFIRMAR SENHA -->
                <Label Grid.Row="8" Text="Confirme a Senha:"/>
                <Entry Grid.Row="9"
                       x:Name="ConfirmarSenhaEntry"
                       Placeholder="******"
                       IsPassword="True"
                       Margin="0,0,0,20"/>

                <!-- BOTÃO -->
                <Button Grid.Row="10"
                        Text="Cadastrar"
                        BackgroundColor="{StaticResource GreenFlag}"
                        Clicked="OnCadastrarClicked"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
