<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Reparai.HomePage"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout
            Padding="24"
            Spacing="20"
            HorizontalOptions="Fill"
            VerticalOptions="Start">

            <!-- Logo -->
            <Image 
                Source="Reparai.jpg"
                Aspect="AspectFit"
                HeightRequest="180"
                HorizontalOptions="Center" />

            <!-- Título -->
            <Label
                Text="Reparai"
                FontSize="32"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#1F2937" />

            <!-- Subtítulo -->
            <Label
                Text="Reporte problemas urbanos com Inteligência Artificial"
                FontSize="18"
                HorizontalTextAlignment="Center"
                TextColor="#4B5563" />

            <!-- Descrição -->
            <Label
                Text="Reporte buracos, iluminação quebrada, lixo irregular e outros problemas urbanos em São Paulo. Seja protagonista na transformação do seu bairro usando tecnologia e IA."
                FontSize="14"
                TextColor="#6B7280"
                HorizontalTextAlignment="Center" />

            <!-- Imagem ilustrativa -->
            <Image
                Source="opengraph_image.png"
                Aspect="AspectFit"
                HeightRequest="200"
                HorizontalOptions="Center" />

            <!-- Botões -->
            <Button
                Text="Reportar Problema"
                BackgroundColor="#2563EB"
                TextColor="White"
                CornerRadius="12"
                HeightRequest="48"
                HorizontalOptions="Fill"
                Clicked="OnReportarProblemaClicked" />

            <Button
                Text="Acompanhar Relatos"
                BackgroundColor="#E5E7EB"
                TextColor="#111827"
                CornerRadius="12"
                HeightRequest="48"
                HorizontalOptions="Fill"
                Clicked="OnAcompanharRelatosClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>